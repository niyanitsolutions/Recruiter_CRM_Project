# ─────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables — Copy to .env and fill in your values
# NEVER commit .env to Git (but .env.production is safe — no secrets)
# ─────────────────────────────────────────────────────────────────────────────

# API base URL
# Local dev (Vite proxy handles /api → localhost:8000):
VITE_API_URL=/api/v1

# Production (direct to your backend domain):
# VITE_API_URL=https://api.yourdomain.com/api/v1

# Razorpay public key — safe to expose in frontend
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
# Production: use live key
# VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx

# App display name
VITE_APP_NAME=CRM Platform
