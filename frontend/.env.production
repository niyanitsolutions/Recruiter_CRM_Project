# Production environment — used by: npm run build
# This file IS safe to commit (no secrets, only public config)
#
# VITE_API_URL: use a relative path (/api/v1) when nginx proxies /api → backend,
# or set to your full backend URL (https://api.yourdomain.com/api/v1) when
# the frontend and backend are on different domains.
VITE_API_URL=/api/v1
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
VITE_APP_NAME=CRM Platform
