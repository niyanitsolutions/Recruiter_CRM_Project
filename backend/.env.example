# ─────────────────────────────────────────────────────────────────────────────
# Niyan HireFlow — Backend Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME=Niyan HireFlow
APP_VERSION=1.0.0
DEBUG=false

# MongoDB — local dev uses localhost, production uses Atlas URI
MONGODB_URI=mongodb://localhost:27017
# Production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://crmadmin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

MASTER_DB_NAME=master_db

# JWT — CHANGE IN PRODUCTION (min 64 random characters)
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production-must-be-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Production example:
# ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# Razorpay — https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxx

# Security
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

# Redis — sessions, caching, rate limiting
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_CACHE_TTL=300
REDIS_SESSION_TTL=86400
# Production (with password):
# REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379/0

# ── AWS S3 — File uploads (resumes, documents) ────────────────────────────────
# Leave all blank for local-disk storage (development).
# Fill all four for S3 storage (production / staging).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=
# Example production values:
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET_NAME=niyan-hireflow-uploads

# Plan Settings
TRIAL_DAYS=14

# Email / SMTP — Gmail App Password recommended
# Get it: Google Account → Security → 2FA → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Niyan HireFlow
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=15

# Frontend URL — used to build email links (verification, password reset)
FRONTEND_URL=https://yourdomain.com

# Fernet key — encrypts tenant SMTP passwords stored in DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=

# Anthropic / Claude API — resume parsing
ANTHROPIC_API_KEY=

# Seller default commission margin
DEFAULT_SELLER_MARGIN=20.0

# Redis password (production only — leave blank for local dev)
REDIS_PASSWORD=
